{
  "name": "starter-turbo-next-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm next dev --turbopack",
    "build": "pnpm run prisma:migrate:deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "npx prisma generate",
    "prisma:generate:cli": "pnpm dlx @better-auth/cli@latest generate",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "postinstall": "pnpm run prisma:generate",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "@prisma/client": "^7.3.0",
    "@tanstack/react-query": "5",
    "zod": "^4.3.6",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "better-auth": "^1.4.18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@prisma/adapter-neon": "^7.3.0",
    "prisma": "^7.3.0",
    "@trpc/client": "^11.4.4",
    "@trpc/next": "^11.4.4",
    "@trpc/react-query": "^11.4.4",
    "@trpc/server": "^11.4.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=24"
  }
}
